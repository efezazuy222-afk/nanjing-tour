---
import MainLayout from "@src/layouts/MainLayout.astro";
import TourCard from "@src/components/TourCard.astro";
import Pagination from "@src/components/Pagination.astro";

import { getCollection } from "astro:content";
import HeadingSection from "@src/components/HeadingSection.astro";

const allTours = await getCollection("tours");

const maxPerPage = 8;
const currentPage = 1;
const totalPages = Math.ceil(allTours.length / maxPerPage);
const visibleTours = allTours.slice(0, maxPerPage);
---

<MainLayout title="Tours – Ocean Travel">
    <HeadingSection
      title="Explore Tour Packages"
      description="Discover our curated selection of ocean adventures, from serene cruises to thrilling water sports. Find your perfect getaway today."
    />
  <section class="relative py-16 md:py-20 overflow-hidden">
    <div class="max-w-6xl mx-auto px-4">

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {visibleTours.map((tour) => (
          <TourCard tour={tour} />
        ))}
      </div>

      {totalPages > 1 && (
        <div class="mt-16 flex justify-center">
          <Pagination
            currentPage={currentPage}
            totalPages={totalPages}
            basePath="/tours"
          />
        </div>
      )}

    </div>
  </section>
</MainLayout>
