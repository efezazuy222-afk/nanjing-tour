---
import { Icon } from 'astro-icon/components';

/* =========================
   Types
========================= */
export interface AboutFeature {
  icon: string; // astro-icon name, example: "bi:globe2"
  label: string;
}

export interface AboutStat {
  value: string;
  label: string;
}

export interface AboutSectionProps {
  id?: string;
  title: string;
  description: string[];
  features: AboutFeature[];
  stats: AboutStat[];
}

/* =========================
   Default / Sample Data
========================= */
const {
  id = "about",
  title = "About Our Ocean Journeys",
  description = [
    "We are an international marine travel company dedicated to creating unforgettable ocean experiences across the world’s most breathtaking destinations.",
    "From tropical snorkeling escapes to luxury liveaboard adventures, every journey is designed with safety, sustainability, and authentic local expertise at its core.",
  ],
  features = [
    { icon: "bi:globe2", label: "Global Destinations" },
    { icon: "bi:award", label: "Certified Operators" },
  ],
  stats = [
    { value: "12+", label: "Ocean Destinations" },
    { value: "5K+", label: "Happy Travelers" },
    { value: "150+", label: "Curated Trips" },
    { value: "100%", label: "Licensed & Insured" },
  ],
} = Astro.props as AboutSectionProps;
---

<!-- About Section -->
<section
  id={id}
  class="relative py-16 md:py-20 bg-blue-900/20 overflow-hidden"
>
  <div class="max-w-6xl mx-auto px-4">
    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 items-center">

      <!-- Text -->
      <div>
        <h2 class="text-3xl md:text-4xl font-semibold text-white">
          {title}
        </h2>

        {description.map((text) => (
          <p class="mt-4 text-white/70 leading-relaxed">
            {text}
          </p>
        ))}

        <div class="mt-6 flex flex-col md:flex-row md:items-center gap-4 text-white/80">
          {features.map((item) => (
            <div class="flex items-center gap-2">
              <Icon name={item.icon} class="w-5 h-5" />
              <span>{item.label}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-2 gap-6">
        {stats.map((stat) => (
          <div class="rounded-2xl bg-white/5 border border-white/10 p-6 backdrop-blur">
            <div class="text-3xl font-semibold text-white">
              {stat.value}
            </div>
            <div class="mt-1 text-white/70">
              {stat.label}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>